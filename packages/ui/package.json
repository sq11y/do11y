{
  "name": "@do11y/ui",
  "description": "The UI for @do11y/docs - a very bare-bones tool to help document Vue components.",
  "version": "0.0.3",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/sq11y/do11y"
  },
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" -- && copyfiles -f src/**.js dist",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@vitejs/plugin-vue": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@vue/tsconfig": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vue-tsc": "catalog:"
  }
}
