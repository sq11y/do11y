{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": ["env.d.ts", "src/**/*"],

  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],

    "outDir": "dist",
    "declaration": true,

    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,

    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo"
  }
}
