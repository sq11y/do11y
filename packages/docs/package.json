{
  "name": "@do11y/docs",
  "description": "A very bare-bones tool to help document Vue components.",
  "version": "0.0.13",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/sq11y/do11y"
  },
  "scripts": {
    "build": "tsc && copyfiles -f src/html/template.html dist/html",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "bin",
    "dist",
    "template",
    "types.d.ts"
  ],
  "bin": {
    "do11y": "./bin/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": "./types.d.ts"
  },
  "peerDependencies": {
    "@vitejs/plugin-vue": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "dependencies": {
    "@do11y/ui": "workspace:*",
    "@mdit-vue/plugin-component": "^3.0.2",
    "@mdit-vue/plugin-frontmatter": "^3.0.2",
    "@mdit-vue/plugin-sfc": "^3.0.2",
    "change-case": "^5.4.4",
    "fast-glob": "^3.3.3",
    "front-matter": "^4.0.2",
    "markdown-it": "^14.1.0",
    "markdown-it-attrs": "^4.3.1",
    "v-custom-block": "catalog:",
    "vue-component-meta": "^3.1.8"
  },
  "devDependencies": {
    "@tsconfig/node24": "catalog:",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-attrs": "^4.1.3",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
